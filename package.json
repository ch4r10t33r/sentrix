{
  "name": "@ch4r10teer41/sentrix-cli",
  "version": "1.12.0",
  "description": "Scaffold P2P-discoverable, DID-native AI agents that interoperate across any framework",
  "bin": {
    "sentrix": "./bin/sentrix.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.7",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sentrix",
    "agent",
    "agent-mesh",
    "interoperability",
    "p2p",
    "libp2p",
    "did",
    "discovery",
    "ai-agents",
    "langgraph",
    "crewai",
    "cli",
    "scaffold"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ch4r10t33r/sentrix.git"
  },
  "bugs": {
    "url": "https://github.com/ch4r10t33r/sentrix/issues"
  },
  "homepage": "https://github.com/ch4r10t33r/sentrix#readme",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": ["main", "master"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      ["@semantic-release/changelog", {
        "changelogFile": "CHANGELOG.md"
      }],
      ["@semantic-release/git", {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }],
      "@semantic-release/github"
    ]
  }
}
